# Clerk authentication. Get these from the Clerk dashboard for your instance.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Where Clerk mounts its sign-in and sign-up flows.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Used only when the request carries no redirect_url of its own.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/overview
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/overview

# Public origin for metadataBase and the Open Graph tags. Must be the brand domain.
NEXT_PUBLIC_SITE_URL=
